# Public client-side configuration used by the static Vite build.
# These values are intentionally prefixed with VITE_ so they can be exposed to the browser.

VITE_FORM_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Set to true for local visual-audit builds when you want a zero-external-network run.
VITE_DISABLE_ANALYTICS=false
