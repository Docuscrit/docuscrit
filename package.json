{
  "name": "docuscrit-official-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild-routes.js",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "capture": "node scripts/capture.js",
    "validate:launch": "node scripts/validate-launch.js",
    "verify": "npm run typecheck && npm run lint && npm run build && npm run validate:launch"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "@vitejs/plugin-react": "6.0.2",
    "vite": "8.0.16"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.19.0"
  }
}
